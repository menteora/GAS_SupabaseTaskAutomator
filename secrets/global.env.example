# =============================================================================
#  secrets/global.env  —  VALORI REALI DEI SECRETS
#  NON committare questo file (è in .gitignore).
#  Copia questo esempio in global.env e compila i valori reali.
# =============================================================================
#
#  Convenzione di naming:
#    <GRUPPO>_SUPABASE_URL=...
#    <GRUPPO>_SUPABASE_KEY=...
#
#  Il <GRUPPO> viene referenziato nei file secrets/<PROGETTO>.env tramite mapping.
#  Puoi aggiungere qualsiasi altra variabile con nome libero (es. CIPPA_SHEET_ID).

BANCOLINI_SUPABASE_URL=https://yyyy.supabase.co
BANCOLINI_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

MENTEORA_SUPABASE_URL=https://yyyy.supabase.co
MENTEORA_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Variabili custom (non Supabase)
# CUSTOM_REMINDER_SHEET_ID=1BxiMVBxxx...
