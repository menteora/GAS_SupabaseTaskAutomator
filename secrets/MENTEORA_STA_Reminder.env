# ID dello script GAS (usato da clasp clone/pull)
SCRIPT_ID=11VVysPibWiEQDfi7ELnSweGHPnwqrRnPakaDemINzR04L5m82wMBKLO8

# File da copiare in questo progetto (separati da virgola)
COPY_FILES=STASupabase.js,STAReminder.js,STATriggers.js

# Mapping Script Property → valore
# Due formati supportati:
#   NOME_PROPERTY=NOME_VARIABILE_IN_GLOBAL_ENV   (valore risolto da global.env — per secrets)
#   NOME_PROPERTY=valore_diretto                 (valore letterale — per config non segrete)
SUPABASE_URL=MENTEORA_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=MENTEORA_SUPABASE_KEY
# Esempio valore diretto (non segreto):
# REMINDER_SHEET_ID=1BxiMVBxxx...
